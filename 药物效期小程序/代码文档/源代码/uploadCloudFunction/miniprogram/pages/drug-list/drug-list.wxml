<view class="page">
  <view class="header">
    <view class="title-block">
      <text class="eyebrow">库存索引</text>
      <text class="page-title">药品列表</text>
    </view>
    <view class="sort-trigger" bindtap="toggleSortPanel">
      <text>排序</text>
    </view>
  </view>

  <view class="sort-panel {{sortPanelClass}}">
    <view class="sort-option" bindtap="switchSort" data-sort="expiryCountdown">
      <text>按效期倒计时</text>
    </view>
    <view class="sort-option" bindtap="switchSort" data-sort="name">
      <text>按药品名称</text>
    </view>
    <view class="sort-option" bindtap="switchSort" data-sort="createdAt">
      <text>按录入时间</text>
    </view>
  </view>

  <view class="search-card">
    <text class="search-label">搜索</text>
    <input placeholder="药名、状态、数量" bindinput="onSearchInput" value="{{searchKeyword}}" />
  </view>

  <scroll-view class="chips" scroll-x enhanced show-scrollbar="{{false}}">
    <view wx:for="{{chips}}" wx:key="key" class="chip {{item.activeClass}}" bindtap="switchFilter" data-filter="{{item.key}}">
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <scroll-view class="list" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{isEmpty}}" class="empty-card">
      <text class="empty-title">暂无药品</text>
      <text class="empty-desc">通过手动、拍照或语音录入后，药品会按效期自动排序。</text>
    </view>

      <view wx:else>
        <view wx:for="{{filteredDrugs}}" wx:key="id" class="drug-card {{item.focusClass}}">
        <view class="drug-icon {{item.iconClass}}">
          <image class="drug-icon-img" src="{{item.iconSrc}}" mode="aspectFit"></image>
        </view>

        <view class="drug-body">
          <view class="drug-top">
            <text class="drug-name">{{item.name}}</text>
            <text class="status-pill {{item.statusClass}}">{{item.statusText}}</text>
          </view>

          <view class="drug-meta">
            <text>{{item.formText}}</text>
            <text>{{item.openState}}</text>
            <text>{{item.qty}}</text>
          </view>

          <view class="drug-bottom">
            <text class="days-text">{{item.displayDays}}</text>
            <view class="actions">
              <view class="action-btn" bindtap="editDrug" data-id="{{item.id}}">
                <text>编辑</text>
              </view>
              <view class="action-btn danger-btn" bindtap="deleteDrug" data-id="{{item.id}}">
                <text>删除</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
