.container {
  width: 100%;
  min-height: 100vh;
  background: #f5f8fd;
}

.screen {
  width: 100%;
  min-height: 100vh;
  background: #f5f8fd;
}

.content {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(47, 128, 237, 0.22);
}

.logo-icon-img {
  width: 100%;
  height: 100%;
}

.app-name {
  margin-bottom: 8rpx;
  color: #1f2937;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
}

.app-version {
  color: #94a3b8;
  font-size: 23rpx;
}

.card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.05);
}

.card-title {
  display: block;
  margin-bottom: 14rpx;
  padding-left: 18rpx;
  position: relative;
  color: #1f2937;
  font-size: 29rpx;
  line-height: 1.35;
  font-weight: 700;
}

.card-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 6rpx;
  width: 7rpx;
  height: 26rpx;
  border-radius: 4rpx;
  background: #2563eb;
}

.card-desc {
  display: block;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.6;
}

.features {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.feature-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #dbeafe;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-icon-img {
  width: 34rpx;
  height: 34rpx;
}
.feature-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.feature-name {
  color: #1f2937;
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 700;
}

.feature-desc {
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.45;
}

.contact-item {
  padding: 18rpx 0;
  border-bottom: 2rpx solid #eef2f7;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-left,
.contact-right {
  min-width: 0;
  display: flex;
  align-items: flex-start;
}

.contact-left {
  flex-shrink: 0;
  gap: 12rpx;
  align-items: center;
}

.contact-right {
  flex: 1;
  justify-content: flex-end;
  gap: 12rpx;
  align-items: center;
}

.contact-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
  background: #eef2ff;
  flex-shrink: 0;
}

.contact-icon-img {
  width: 26rpx;
  height: 26rpx;
}

.copy-text {
  flex-shrink: 0;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
}

.contact-left text {
  color: #1f2937;
  font-size: 26rpx;
}

.contact-right text {
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.4;
  text-align: right;
  word-break: break-all;
}

.copyright {
  padding: 34rpx 0 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  text-align: center;
}

.copyright text {
  color: #94a3b8;
  font-size: 23rpx;
}

.home-indicator {
  display: none;
}
