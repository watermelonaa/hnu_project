.page {
  width: 100%;
  min-height: 100vh;
  background: #f6f8fb;
  display: flex;
  flex-direction: column;
}

.topbar {
  padding: 18rpx 32rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title-block {
  display: flex;
  flex-direction: column;
}

.eyebrow {
  color: #7b8496;
  font-size: 22rpx;
  line-height: 1.3;
}

.page-title {
  margin-top: 4rpx;
  color: #1d2433;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 800;
}

.content {
  flex: 1;
  min-height: 0;
  padding: 0 28rpx 140rpx;
}

.hero-card {
  min-height: 240rpx;
  padding: 34rpx 32rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #3d7cff 0%, #55d6b6 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 22rpx 48rpx rgba(61, 124, 255, 0.24);
}

.hero-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hero-title {
  color: #ffffff;
  font-size: 38rpx;
  line-height: 1.28;
  font-weight: 800;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 25rpx;
  line-height: 1.45;
}

.hero-mark {
  width: 96rpx;
  height: 96rpx;
  margin-left: 24rpx;
  border-radius: 30rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-icon {
  width: 100%;
  height: 100%;
}

.stat-row {
  margin-top: 24rpx;
  display: flex;
  gap: 18rpx;
}

.stat-card {
  flex: 1;
  min-width: 0;
  padding: 24rpx 12rpx;
  border-radius: 28rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.08);
}

.stat-value {
  font-size: 46rpx;
  line-height: 1;
  font-weight: 900;
}

.stat-label {
  margin-top: 10rpx;
  color: #7b8496;
  font-size: 23rpx;
}

.danger .stat-value {
  color: #ff5a5f;
}

.warning .stat-value {
  color: #ff9f2e;
}

.success .stat-value {
  color: #28b981;
}

.section-head {
  margin: 40rpx 4rpx 20rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.section-title {
  color: #1d2433;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 800;
}

.section-note,
.view-more {
  color: #7b8496;
  font-size: 23rpx;
}

.action-row {
  display: flex;
  gap: 22rpx;
}

.action-card {
  flex: 1;
  min-width: 0;
  min-height: 190rpx;
  padding: 34rpx 24rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.07);
}

.action-card.featured {
  border: 1rpx solid rgba(79, 124, 255, 0.04);
}

.action-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-camera {
  background: #1677ff;
}

.action-voice {
  background: #6d5df6;
}

.action-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.action-title {
  margin-top: 24rpx;
  color: #1d2433;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 800;
}

.action-desc {
  margin-top: 6rpx;
  color: #9aa3b5;
  font-size: 22rpx;
  white-space: nowrap;
}

.manual-button {
  width: 100%;
  min-height: 80rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border: 1rpx solid rgba(79, 124, 255, 0.24);
  border-radius: 999rpx;
  background: #f8fbff;
  color: #1d2433;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.manual-button::after {
  border: none;
}

.button-plus {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  filter: invert(45%) sepia(92%) saturate(2077%) hue-rotate(207deg) brightness(101%) contrast(101%);
}

.focus-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.08);
}

.focus-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.empty-state {
  margin-top: 22rpx;
  padding: 34rpx 24rpx;
  border-radius: 24rpx;
  background: #f7fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-title {
  color: #1d2433;
  font-size: 28rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 8rpx;
  color: #9aa3b5;
  font-size: 24rpx;
}

.reminder-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
}

.reminder-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eef1f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.reminder-name {
  color: #1d2433;
  font-size: 28rpx;
  font-weight: 800;
}

.reminder-meta {
  margin-top: 6rpx;
  color: #9aa3b5;
  font-size: 23rpx;
}

.status-pill {
  flex-shrink: 0;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.tag-danger {
  color: #d92d3a;
  background: #fff0f1;
}

.tag-warning {
  color: #b76b00;
  background: #fff7e8;
}
