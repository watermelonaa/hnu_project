.page {
  width: 100%;
  min-height: 100vh;
  background: #f6f8fb;
}

.content {
  height: 100vh;
  padding: 28rpx 24rpx 64rpx;
}

.user-card {
  margin-bottom: 22rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #4f7cff 0%, #32c5ff 100%);
  box-shadow: 0 18rpx 42rpx rgba(79, 124, 255, 0.22);
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.65);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.eyebrow {
  font-size: 23rpx;
  line-height: 1.3;
  color: rgba(255, 255, 255, 0.78);
}

.user-name {
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-desc {
  font-size: 24rpx;
  line-height: 1.35;
  color: rgba(255, 255, 255, 0.92);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-chip {
  flex-shrink: 0;
  min-width: 76rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-chip text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.health-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(33, 41, 61, 0.06);
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.08);
}

.health-top {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.health-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.health-label {
  font-size: 23rpx;
  line-height: 1.3;
  color: #9aa3b5;
}

.health-title {
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1d2433;
}

.health-desc {
  font-size: 24rpx;
  line-height: 1.45;
  color: #7b8496;
}

.score-ring {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #eef2ff;
  border: 8rpx solid #4f7cff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-value {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 900;
  color: #4f7cff;
}

.score-unit {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1;
  color: #7b8496;
}

.risk-row {
  margin-top: 22rpx;
  display: flex;
  gap: 12rpx;
}

.risk-pill {
  flex: 1;
  min-width: 0;
  min-height: 64rpx;
  padding: 10rpx 12rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.risk-pill.danger {
  background: #fff1f2;
  color: #d92d3a;
}

.risk-pill.total {
  background: #eef2ff;
  color: #4f7cff;
}

.risk-pill.warning {
  background: #fff7ed;
  color: #c56a10;
}

.risk-pill.ok {
  background: #ecfdf5;
  color: #16794b;
}

.risk-value {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 900;
}

.risk-label {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
}

.quick-section {
  margin-bottom: 24rpx;
}

.section-row {
  margin: 0 4rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.section-note {
  font-size: 23rpx;
  color: #9aa3b5;
  flex-shrink: 0;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.quick-card {
  width: calc((100% - 14rpx) / 2);
  min-height: 136rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(33, 41, 61, 0.06);
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.08);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quick-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 20rpx;
  background: #1d2433;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-img {
  width: 36rpx;
  height: 36rpx;
}

.quick-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.quick-title {
  font-size: 27rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #1d2433;
}

.quick-desc {
  font-size: 22rpx;
  line-height: 1.3;
  color: #9aa3b5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-section {
  margin-bottom: 26rpx;
}

.section-title {
  display: block;
  margin: 0 4rpx 14rpx;
  font-size: 25rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #4b5565;
}

.menu-heading {
  margin-top: 0;
}

.menu-group {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(33, 41, 61, 0.06);
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.08);
}

.menu-item {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #f0f3f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-name {
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1d2433;
}

.menu-desc {
  font-size: 23rpx;
  line-height: 1.35;
  color: #9aa3b5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  flex-shrink: 0;
  font-size: 42rpx;
  line-height: 1;
  color: #c0c7d4;
}

.editor-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: none;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.42);
}

.editor-mask.show {
  display: flex;
}

.editor-sheet {
  width: 100%;
  max-height: 86vh;
  padding: 30rpx 24rpx 40rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #f6f8fb;
  box-shadow: 0 -18rpx 42rpx rgba(15, 23, 42, 0.16);
}

.editor-head {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.editor-title {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1d2433;
}

.editor-desc {
  font-size: 24rpx;
  line-height: 1.4;
  color: #7b8496;
}

.avatar-editor {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border: 1rpx solid rgba(33, 41, 61, 0.06);
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.08);
}

.editor-avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.avatar-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.avatar-title {
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1d2433;
}

.avatar-desc {
  font-size: 23rpx;
  line-height: 1.35;
  color: #9aa3b5;
}

.editor-field {
  margin-bottom: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 25rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #4b5565;
}

.field-input,
.field-textarea {
  width: 100%;
  border: 2rpx solid #e7ecf5;
  border-radius: 22rpx;
  padding: 0 24rpx;
  background: #ffffff;
  color: #1d2433;
  font-size: 28rpx;
}

.field-input {
  height: 88rpx;
}

.field-textarea {
  min-height: 132rpx;
  padding-top: 20rpx;
  line-height: 1.45;
}

.placeholder {
  color: #a3acbc;
}

.editor-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 8rpx;
}

.editor-btn {
  flex: 1;
  min-height: 92rpx;
  padding: 0;
  border: none;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 800;
}

.editor-btn::after {
  border: none;
}

.editor-btn.ghost {
  background: #eef2ff;
  color: #4f7cff;
}

.editor-btn.main {
  background: #1d2433;
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(29, 36, 51, 0.18);
}
