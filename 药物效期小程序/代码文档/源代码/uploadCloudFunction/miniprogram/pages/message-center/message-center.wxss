.container {
  width: 100%;
  min-height: 100vh;
  background: #f5f8fd;
}

.screen {
  width: 100%;
  height: 100vh;
  background: #f5f8fd;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.clear-btn {
  width: 88rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.clear-btn text {
  color: #ef4444;
  font-size: 26rpx;
}

.content {
  flex: 1;
  min-height: 0;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.toolbar {
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.toolbar-title {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 800;
}

.unread-header {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.unread-text {
  flex: 1;
  min-width: 0;
  color: #2563eb;
  font-size: 25rpx;
  line-height: 1.35;
}

.mark-all {
  flex-shrink: 0;
  color: #2563eb;
  font-size: 24rpx;
}

.loading-state {
  min-height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-state text {
  color: #64748b;
  font-size: 26rpx;
}

.message-item {
  background: #fff;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.05);
}

.message-item.unread {
  background: #f8fbff;
  border-left: 6rpx solid #2563eb;
}

.message-item.read {
  opacity: 0.86;
}

.msg-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.msg-icon.warning-bg {
  background: #fff7ed;
}

.msg-icon.danger-bg {
  background: #fef2f2;
}

.msg-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.msg-content {
  flex: 1;
  min-width: 0;
}

.msg-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.msg-title {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
}

.msg-time {
  flex-shrink: 0;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.35;
}

.msg-desc {
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.45;
  word-break: break-word;
}

.delete-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: #fef2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.delete-icon {
  width: 26rpx;
  height: 26rpx;
}

.empty-state {
  min-height: 420rpx;
  padding: 80rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-title {
  margin-bottom: 14rpx;
  color: #475569;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  max-width: 520rpx;
  color: #94a3b8;
  font-size: 25rpx;
  line-height: 1.45;
}

.home-indicator {
  display: none;
}
