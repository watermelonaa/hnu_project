.page {
  width: 100%;
  min-height: 100vh;
  background: #f6f8fb;
}

.content {
  height: 100vh;
  padding: 28rpx 24rpx 64rpx;
}

.header-card {
  margin-bottom: 22rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #4f7cff 0%, #7a9cff 100%);
  box-shadow: 0 18rpx 42rpx rgba(79, 124, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.header-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.eyebrow {
  margin-bottom: 8rpx;
  font-size: 24rpx;
  line-height: 1.3;
  color: rgba(255, 255, 255, 0.82);
}

.page-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.page-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.88);
}

.header-mark {
  width: 92rpx;
  height: 92rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.header-mark-img {
  width: 54rpx;
  height: 54rpx;
}

.form-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(33, 41, 61, 0.06);
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.08);
}

.section-head {
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1d2433;
}

.section-note {
  font-size: 23rpx;
  line-height: 1.3;
  color: #9aa3b5;
  flex-shrink: 0;
}

.form-field {
  margin-bottom: 24rpx;
}

.form-field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 25rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #4b5565;
}

.field-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e7ecf5;
  border-radius: 22rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1d2433;
  background: #f9fbff;
}

.placeholder {
  color: #a3acbc;
}

.field-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #9aa3b5;
}

.picker-view {
  width: 100%;
  min-height: 88rpx;
  border: 2rpx solid #e7ecf5;
  border-radius: 22rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: #f9fbff;
}

.picker-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #1d2433;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  flex-shrink: 0;
  font-size: 30rpx;
  color: #9aa3b5;
}

.status-row {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.status-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.status-label {
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1d2433;
}

.status-desc {
  font-size: 23rpx;
  line-height: 1.4;
  color: #7b8496;
}

.status-preview {
  max-width: 300rpx;
  border-radius: 999rpx;
  padding: 14rpx 18rpx;
  font-size: 25rpx;
  line-height: 1.3;
  font-weight: 700;
  text-align: center;
  flex-shrink: 0;
}

.save-btn {
  width: 100%;
  min-height: 96rpx;
  margin: 8rpx 0 24rpx;
  padding: 0;
  border: none;
  border-radius: 26rpx;
  background: #1d2433;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 34rpx rgba(29, 36, 51, 0.18);
}

.save-btn::after {
  border: none;
}
