<!-- pages/settings/settings.wxml -->
<view class="container">
  <view class="screen">
    <!-- 主要内容区域 -->
    <view class="content">
      <view class="group">
        <view class="group-title">通知设置</view>
        
        <view class="row">
          <view class="left">
            <view class="icon-cell">
              <image class="icon-img" src="/images/icons/ui/bell-blue.svg" mode="aspectFit"></image>
            </view>
            <text>站内效期提醒</text>
          </view>
          <switch class="switch" 
                  checked="{{reminderPush}}" 
                  bindchange="toggleReminderPush"
                  color="#2F80ED" />
        </view>
        
        <view class="row">
          <view class="left">
            <view class="icon-cell">
              <image class="icon-img" src="/images/icons/ui/clock-blue.svg" mode="aspectFit"></image>
            </view>
            <text>提醒时间</text>
          </view>
          <picker mode="selector" 
                  range="{{timeOptions}}" 
                  value="{{remindTimeIndex}}"
                  bindchange="onRemindTimeChange">
            <view class="picker-value">
              <text>{{remindTime}}</text>
              <text class="arrow">▼</text>
            </view>
          </picker>
        </view>
        
        <view class="row-tip">
          <text>开启后，消息提醒页会根据云数据库中的到期日期生成过期和临期提醒。</text>
        </view>
      </view>

      <!-- 通用设置分组 -->
      <view class="group">
        <view class="group-title">通用设置</view>
        
        <view class="row">
          <view class="left">
            <view class="icon-cell">
              <image class="icon-img" src="/images/icons/ui/sync-blue.svg" mode="aspectFit"></image>
            </view>
            <text>数据同步</text>
          </view>
          <switch class="switch" 
                  checked="{{dataSync}}" 
                  bindchange="toggleDataSync"
                  color="#2F80ED" />
        </view>
        
        <view class="row" bindtap="clearCache">
          <view class="left">
            <view class="icon-cell">
              <image class="icon-img" src="/images/icons/ui/trash-blue.svg" mode="aspectFit"></image>
            </view>
            <text>清除缓存</text>
          </view>
          <view class="right-value">
            <text class="arrow">›</text>
          </view>
        </view>
      </view>

    </view>
  </view>
</view>
