.container {
  width: 100%;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

.screen {
  width: 100%;
  height: 100vh;
  position: relative;
  background: #000;
  overflow: hidden;
}

.camera-preview {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.camera-live {
  width: 100%;
  height: 100%;
}

.camera-bg {
  width: 100%;
  height: 100%;
  filter: brightness(0.85);
}

.camera-empty {
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at center, #1f2937 0%, #0f172a 48%, #020617 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  color: #fff;
}

.focus-frame {
  position: absolute;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%);
  width: 430rpx;
  height: 300rpx;
  max-width: 70vw;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 28rpx;
}

.corner {
  position: absolute;
  width: 52rpx;
  height: 52rpx;
  border-color: rgba(255, 255, 255, 0.74);
}

.corner-left-top {
  top: -2rpx;
  left: -2rpx;
  border-top: 6rpx solid;
  border-left: 6rpx solid;
  border-radius: 24rpx 0 0 0;
}

.corner-right-top {
  top: -2rpx;
  right: -2rpx;
  border-top: 6rpx solid;
  border-right: 6rpx solid;
  border-radius: 0 24rpx 0 0;
}

.corner-left-bottom {
  bottom: -2rpx;
  left: -2rpx;
  border-bottom: 6rpx solid;
  border-left: 6rpx solid;
  border-radius: 0 0 0 24rpx;
}

.corner-right-bottom {
  right: -2rpx;
  bottom: -2rpx;
  border-right: 6rpx solid;
  border-bottom: 6rpx solid;
  border-radius: 0 0 24rpx 0;
}

.empty-title {
  margin-top: 12rpx;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
}

.empty-desc {
  max-width: 520rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
  line-height: 1.35;
  text-align: center;
}

.result-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 190rpx;
  max-height: 220rpx;
  overflow: hidden;
  background: rgba(15, 23, 42, 0.82);
  border-radius: 22rpx;
  padding: 20rpx;
}

.result-title {
  display: block;
  margin-bottom: 12rpx;
  color: #fff;
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 700;
}

.result-item {
  min-width: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
  color: #dbeafe;
  font-size: 23rpx;
  line-height: 1.3;
}

.result-item text:first-child {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-item:last-child {
  border-bottom: none;
}

.top-bar {
  position: absolute;
  top: 72rpx;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 0 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.top-btn {
  min-width: 72rpx;
  height: 60rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-btn text {
  font-size: 24rpx;
  color: #fff;
}

.top-title {
  max-width: 360rpx;
  color: #fff;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  text-align: center;
}

.camera-tip {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  bottom: 210rpx;
  z-index: 10;
  text-align: center;
}

.camera-tip text {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.44);
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  line-height: 1.35;
}

.footer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 24rpx 40rpx 44rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.68));
}

.footer-center {
  text-align: center;
}

.shutter-btn {
  width: 116rpx;
  height: 116rpx;
  margin: 0 auto 18rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  background: rgba(255, 255, 255, 0.2);
  box-shadow: 0 0 0 10rpx rgba(255, 255, 255, 0.18);
}

.shutter-btn.loading {
  border-color: #60a5fa;
  box-shadow: 0 0 0 10rpx rgba(96, 165, 250, 0.25);
}

.shutter-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  line-height: 1.35;
}

.album-btn {
  position: absolute;
  right: 44rpx;
  bottom: 56rpx;
  width: 104rpx;
  min-height: 104rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.24);
}

.album-icon {
  width: 38rpx;
  height: 38rpx;
}

.album-btn text {
  color: #2563eb;
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 700;
}

.entry-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: none;
  flex-direction: column;
  justify-content: flex-end;
  background: rgba(0, 0, 0, 0.48);
}

.entry-overlay.show {
  display: flex;
}

.entry-sheet {
  max-height: 86vh;
  background: #f5f8fd;
  border-radius: 28rpx 28rpx 0 0;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.sheet-header {
  flex-shrink: 0;
  padding: 20rpx 24rpx 14rpx;
  text-align: center;
  border-bottom: 1rpx solid #e2e8f0;
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 16rpx;
  border-radius: 999rpx;
  background: #cbd5e1;
}

.sheet-title {
  display: block;
  color: #1f2937;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.sheet-desc {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.35;
}

.sheet-body {
  flex: 1;
  min-height: 0;
  padding: 20rpx 24rpx;
}

.drug-item {
  background: #fff;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.item-tag {
  margin-bottom: 14rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eef2f7;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.form-field {
  margin-bottom: 16rpx;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.field-input,
.picker-view {
  width: 100%;
  min-height: 74rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 0 18rpx;
  background: #fff;
  font-size: 26rpx;
  color: #1f2937;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.picker-view text:first-child {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
}

.picker-arrow {
  flex-shrink: 0;
  color: #94a3b8;
  font-size: 22rpx;
}

.confidence {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.confidence-high {
  background: #dcfce7;
  color: #15803d;
}

.confidence-mid {
  background: #fef3c7;
  color: #b45309;
}

.confidence-low {
  background: #fee2e2;
  color: #b91c1c;
}

.warning-box {
  margin-bottom: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #fde68a;
  background: #fffbeb;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.warning-box text {
  color: #92400e;
  font-size: 22rpx;
  line-height: 1.4;
}

.sheet-footer {
  flex-shrink: 0;
  padding: 18rpx 24rpx 34rpx;
  display: flex;
  gap: 14rpx;
  background: #f5f8fd;
  border-top: 1rpx solid #e2e8f0;
}

.sheet-footer button,
.cancel-btn,
.save-btn {
  flex: 1;
  min-height: 80rpx;
  padding: 0;
  border: none;
  border-radius: 18rpx;
  font-size: 27rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  background: #f1f5f9;
  color: #64748b;
}

.save-btn {
  background: #2563eb;
  color: #fff;
}

.cancel-btn::after,
.save-btn::after {
  border: none;
}
