.container {
  width: 100%;
  min-height: 100vh;
  background: #f5f8fd;
}

.screen {
  width: 100%;
  height: 100vh;
  background: #f5f8fd;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.content {
  flex: 1;
  min-height: 0;
  padding: 24rpx 24rpx 140rpx;
}

.card {
  background: #fff;
  border-radius: 22rpx;
  padding: 26rpx 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.05);
}

.protocol-header {
  text-align: center;
  margin-bottom: 26rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #eef2f7;
}

.protocol-title {
  display: block;
  margin-bottom: 12rpx;
  color: #1f2937;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 800;
}

.protocol-version,
.protocol-date {
  display: block;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.4;
}

.protocol-notice {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f0fdf4;
}

.protocol-notice text {
  color: #166534;
  font-size: 25rpx;
  line-height: 1.55;
}

.protocol-section {
  margin-bottom: 24rpx;
}

.section-title {
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  width: 8rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: #2563eb;
  flex-shrink: 0;
}

.section-title text {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
}

.section-content {
  display: block;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.65;
}

.contact-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #eef2f7;
}

.contact-item {
  padding: 14rpx 0;
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 8rpx;
}

.contact-label,
.contact-value {
  font-size: 25rpx;
  line-height: 1.45;
}

.contact-label {
  color: #64748b;
}

.contact-value {
  color: #2563eb;
}

.contact-company {
  display: block;
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 23rpx;
  line-height: 1.4;
}

.copy-icon {
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 700;
}

.copyright {
  padding: 34rpx 0 16rpx;
  text-align: center;
}

.copyright text {
  color: #94a3b8;
  font-size: 23rpx;
}

.home-indicator {
  display: none;
}
