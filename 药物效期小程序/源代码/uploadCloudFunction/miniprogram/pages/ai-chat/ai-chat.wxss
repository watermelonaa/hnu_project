.page {
  width: 100%;
  min-height: 100vh;
  background: #f6f8fb;
}

.chat {
  height: 100vh;
  padding: 28rpx 24rpx 190rpx;
}

.assistant-card {
  margin-bottom: 20rpx;
  padding: 26rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #1d2433 0%, #4f7cff 100%);
  box-shadow: 0 18rpx 42rpx rgba(79, 124, 255, 0.2);
}

.assistant-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.assistant-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.assistant-icon-img {
  width: 42rpx;
  height: 42rpx;
}

.assistant-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.assistant-title {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #ffffff;
}

.assistant-desc {
  font-size: 24rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.84);
}

.clear-btn {
  min-width: 76rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.clear-btn text {
  font-size: 23rpx;
  font-weight: 700;
  color: #ffffff;
}

.tool-row,
.quick-row {
  width: 100%;
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.tool-chip,
.quick-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 280rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  padding: 15rpx 20rpx;
  line-height: 1.2;
}

.tool-chip text,
.quick-chip text {
  font-size: 24rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-chip {
  background: #4f7cff;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(79, 124, 255, 0.18);
}

.quick-chip {
  background: #ffffff;
  color: #4f7cff;
  border: 2rpx solid #dce6ff;
}

.message-list {
  margin-top: 10rpx;
}

.msg {
  display: flex;
  margin-bottom: 20rpx;
}

.msg.ai {
  justify-content: flex-start;
}

.msg.user {
  justify-content: flex-end;
}

.bubble {
  max-width: 82%;
  border-radius: 26rpx;
  padding: 20rpx 24rpx;
  font-size: 27rpx;
  line-height: 1.5;
  box-shadow: 0 12rpx 28rpx rgba(35, 48, 78, 0.08);
  word-break: break-word;
}

.ai .bubble {
  background: #ffffff;
  border-top-left-radius: 10rpx;
  color: #1d2433;
}

.user .bubble {
  background: #4f7cff;
  color: #ffffff;
  border-top-right-radius: 10rpx;
}

.bubble.loading {
  color: #7b8496;
}

.bottom-placeholder {
  height: 20rpx;
}

.input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 20rpx 34rpx;
  background: rgba(246, 248, 251, 0.96);
  z-index: 20;
}

.input-wrapper {
  min-height: 92rpx;
  background: #ffffff;
  border-radius: 26rpx;
  padding: 12rpx 12rpx 12rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 12rpx 34rpx rgba(35, 48, 78, 0.14);
  border: 2rpx solid #e7ecf5;
}

.input-icon {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-icon-img {
  width: 30rpx;
  height: 30rpx;
}

.chat-input {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  font-size: 27rpx;
  color: #1d2433;
}

.placeholder {
  color: #a3acbc;
}

.send-btn {
  flex-shrink: 0;
  min-width: 92rpx;
  height: 66rpx;
  border-radius: 20rpx;
  background: #1d2433;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 14rpx;
}

.send-btn.disabled {
  opacity: 0.55;
}

.send-btn text {
  font-size: 25rpx;
  font-weight: 700;
}
