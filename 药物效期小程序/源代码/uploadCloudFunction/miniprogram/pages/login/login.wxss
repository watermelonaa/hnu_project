.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #eaf1ff, #f5f8fd);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.content {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.logo {
  text-align: center;
  margin-bottom: 70rpx;
}

.logo-icon {
  width: 132rpx;
  height: 132rpx;
  margin: 0 auto 28rpx;
  border-radius: 34rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(47, 128, 237, 0.22);
}

.logo-icon-img {
  width: 100%;
  height: 100%;
}

.title {
  display: block;
  margin-bottom: 12rpx;
  color: #1e293b;
  font-size: 46rpx;
  line-height: 1.25;
  font-weight: 800;
}

.subtitle {
  display: block;
  color: #64748b;
  font-size: 26rpx;
}

.auth-buttons {
  width: 100%;
}

.wx-login-btn {
  width: 100%;
  min-height: 92rpx;
  padding: 0;
  border: none;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.wx-login-btn {
  background: #07c160;
  box-shadow: 0 12rpx 28rpx rgba(7, 193, 96, 0.22);
}

.wx-login-btn text {
  color: #fff;
  font-size: 31rpx;
  font-weight: 700;
}

.wx-login-btn::after {
  border: none;
}

.agreement {
  margin-top: 34rpx;
  padding: 0 16rpx;
  text-align: center;
  color: #7b8496;
  font-size: 23rpx;
  line-height: 1.7;
}

.link {
  color: #2563eb;
  font-weight: 700;
}

.privacy-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: rgba(15, 23, 42, 0.46);
}

.privacy-modal.show {
  display: flex;
}

.modal-content {
  width: 100%;
  max-width: 640rpx;
  padding: 42rpx 34rpx 34rpx;
  border-radius: 34rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 28rpx 70rpx rgba(15, 23, 42, 0.22);
  box-sizing: border-box;
}

.modal-icon {
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 20rpx;
  border-radius: 24rpx;
  background: #ecfdf5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-icon-img {
  width: 42rpx;
  height: 42rpx;
}

.modal-symbol {
  color: #10b981;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 800;
}

.modal-title {
  display: block;
  margin-bottom: 16rpx;
  color: #1d2433;
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 800;
}

.modal-desc {
  margin: 0 auto 36rpx;
  max-width: 536rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  text-align: left;
}

.modal-desc text {
  color: #6b7484;
  font-size: 25rpx;
  line-height: 1.6;
}

.modal-buttons {
  display: flex;
  gap: 18rpx;
}

.modal-buttons button {
  flex: 1;
  min-height: 88rpx;
  padding: 0;
  border: none;
  border-radius: 22rpx;
  font-size: 29rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-disagree {
  background: #f3f6fb;
  color: #6b7484;
}

.btn-agree {
  background: #07c160;
  color: #fff;
  box-shadow: 0 12rpx 26rpx rgba(7, 193, 96, 0.24);
}

.btn-disagree::after,
.btn-agree::after {
  border: none;
}

.agreement-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  display: none;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.46);
}

.agreement-modal.show {
  display: flex;
}

.agreement-content {
  width: 100%;
  max-height: 82vh;
  padding: 34rpx 32rpx 40rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.agreement-title {
  margin-bottom: 22rpx;
  color: #1d2433;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  text-align: center;
}

.agreement-scroll {
  max-height: 56vh;
  padding-right: 6rpx;
  box-sizing: border-box;
}

.agreement-section-title {
  display: block;
  margin: 22rpx 0 8rpx;
  color: #1d2433;
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 800;
}

.agreement-section-title:first-child {
  margin-top: 0;
}

.agreement-section-text {
  display: block;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.65;
}

.agreement-close {
  width: 100%;
  min-height: 88rpx;
  margin-top: 28rpx;
  padding: 0;
  border: none;
  border-radius: 22rpx;
  background: #1d2433;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement-close::after {
  border: none;
}
