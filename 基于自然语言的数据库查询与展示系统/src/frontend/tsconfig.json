{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "preserve",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["*.d.ts", "**/*.ts", "**/*.tsx", "App.vue", "src/views/QueryPage.vue", "src/views/AccountPage.vue", "src/views/NotificationsPage.vue", "src/components/ChatModal.vue", "src/components/SideBars/DataAdminSidebar.vue", "src/views/PlaceholderPage.vue", "src/components/SideBars/SysAdminSidebar.vue", "src/views/HistoryPage.vue", "src/components/admin/AdminModal.vue", "src/views/admin/AdminAccountPage.vue", "src/views/admin/DashboardPage.vue", "src/views/admin/LLMConfigPage.vue", "src/views/admin/NotificationManagementPage.vue", "src/views/data-admin/DataAdminDashboardPage.vue", "src/components/ComparisonModal.vue", "src/views/admin/SysAdminPage.vue", "src/views/admin/UserManagementPage.vue", "src/views/admin/SystemLogPage.vue", "src/views/CollectionsPage.vue", "src/views/data-admin/ConnectionLogPage.vue", "src/views/data-admin/DataSourceManagementPage.vue", "src/views/data-admin/DataAdminNotificationPage.vue", "src/views/data-admin/UserPermissionPage.vue", "src/views/DataAdminPage.vue"]
